{
  "name": "mixtape-matchmaker-server",
  "version": "2.0.0",
  "private": true,
  "description": "Express API and Socket.IO server for Mixtape Matchmaker.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:make": "knex migrate:make",
    "check": "find src migrations -name '*.js' -print0 | xargs -0 -n1 node --check"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "mysql2": "^3.15.3",
    "better-sqlite3": "^12.4.6",
    "socket.io": "^4.8.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}
